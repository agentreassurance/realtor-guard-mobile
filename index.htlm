<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Realtor Guard</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,Helvetica,sans-serif;
}

body{
background:#ffffff;
display:flex;
justify-content:center;
}

.phone{

max-width:430px;
width:100%;
min-height:100vh;
padding:20px;

}

.logo{

width:230px;
display:block;
margin:30px auto 15px;

}

h1{

text-align:center;
color:#d40000;
font-size:42px;
font-weight:bold;

}

.tagline{

text-align:center;
color:#555;
font-size:18px;
margin-top:8px;

}

.wegotyou{

text-align:center;
color:#d40000;
font-size:28px;
font-weight:bold;
margin:20px 0 35px;

}

.button{

display:block;
text-decoration:none;
background:white;
color:#d40000;
border:2px solid #d40000;
border-radius:18px;
padding:22px;
font-size:24px;
font-weight:bold;
margin-bottom:20px;
text-align:center;
box-shadow:0 5px 15px rgba(0,0,0,.08);

}

.button:hover{

background:#d40000;
color:white;

}

.footer{

margin-top:40px;
text-align:center;
font-size:18px;
color:#666;

}

.footer strong{

color:#d40000;

}

</style>

</head>

<body>

<div class="phone">

<img src="logo.png" class="logo">

<h1>REALTOR GUARD</h1>

<div class="tagline">
Never Alone at a Showing or Open House
</div>

<div class="wegotyou">
WE GOT YOU
</div>

<a href="#" class="button">New Agent</a>

<a href="#" class="button">Agent Dashboard</a>

<a href="#" class="button">New Observer</a>

<a href="#" class="button">Observer Dashboard</a>

<div class="footer">
<strong>Virginia Active</strong><br>
More states coming soon.
</div>

</div>

</body>
</html>

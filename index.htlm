<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta
    name="viewport"
    content="width=device-width, initial-scale=1, viewport-fit=cover"
  >
  <meta name="theme-color" content="#d60000">
  <title>Realtor Guard</title>

  <style>
    :root {
      --red: #d60000;
      --dark-red: #b40000;
      --light-red: #fff1f1;
      --black: #151515;
      --gray: #555555;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    html,
    body {
      min-height: 100%;
      background: #ffffff;
      font-family: Arial, Helvetica, sans-serif;
      color: var(--black);
    }

    body {
      display: flex;
      justify-content: center;
    }

    .app {
      width: 100%;
      max-width: 480px;
      min-height: 100vh;
      background: #ffffff;
      padding-bottom: calc(28px + env(safe-area-inset-bottom));
    }

    .header {
      min-height: 105px;
      padding:
        calc(18px + env(safe-area-inset-top))
        20px
        22px;
      background: linear-gradient(135deg, #ed1111, var(--dark-red));
      border-radius: 0 0 42px 42px;
      display: flex;
      justify-content: center;
      align-items: flex-end;
      position: relative;
      color: #ffffff;
    }

    .menu-button {
      position: absolute;
      left: 20px;
      bottom: 21px;
      border: 0;
      background: transparent;
      color: #ffffff;
      font-size: 36px;
      cursor: pointer;
    }

    .header-title {
      text-align: center;
      font-size: 24px;
      font-weight: 900;
      letter-spacing: 0.5px;
    }

    .header-icon {
      display: block;
      margin-bottom: 3px;
      font-size: 25px;
    }

    .content {
      padding: 18px;
    }

    .logo {
      display: block;
      width: 100%;
      max-width: 390px;
      height: auto;
      margin: 0 auto 20px;
    }

    .navigation {
      display: grid;
      gap: 15px;
    }

    .nav-card {
      min-height: 104px;
      padding: 15px;
      border: 2px solid var(--red);
      border-radius: 17px;
      background: #ffffff;
      color: inherit;
      text-decoration: none;
      display: grid;
      grid-template-columns: 62px 1fr 28px;
      align-items: center;
      gap: 14px;
      box-shadow: 0 7px 16px rgba(0, 0, 0, 0.09);
      transition: transform 0.12s ease, background 0.12s ease;
      -webkit-tap-highlight-color: transparent;
    }

    .nav-card:active {
      transform: scale(0.98);
      background: #fff8f8;
    }

    .nav-icon {
      width: 62px;
      height: 62px;
      border-radius: 50%;
      background: var(--light-red);
      color: var(--red);
      display: grid;
      place-items: center;
      font-size: 30px;
      font-weight: 700;
    }

    .nav-title {
      display: block;
      color: var(--dark-red);
      font-size: 21px;
      line-height: 1.1;
      font-weight: 900;
      text-transform: uppercase;
    }

    .nav-description {
      display: block;
      margin-top: 7px;
      color: #444444;
      font-size: 15px;
      line-height: 1.25;
    }

    .arrow {
      color: var(--red);
      font-size: 42px;
      line-height: 1;
      text-align: right;
    }

    .location-card {
      margin-top: 22px;
      padding: 20px 18px;
      border-radius: 17px;
      background: var(--light-red);
      display: grid;
      grid-template-columns: 58px 1fr;
      align-items: center;
      gap: 14px;
    }

    .location-icon {
      color: var(--red);
      font-size: 42px;
      text-align: center;
    }

    .location-title {
      color: var(--dark-red);
      font-size: 20px;
      font-weight: 900;
      text-transform: uppercase;
    }

    .location-text {
      margin-top: 5px;
      color: var(--gray);
      font-size: 16px;
    }

    @media (max-width: 360px) {
      .content {
        padding-left: 12px;
        padding-right: 12px;
      }

      .nav-card {
        grid-template-columns: 54px 1fr 22px;
        gap: 10px;
        padding: 13px 12px;
      }

      .nav-icon {
        width: 54px;
        height: 54px;
        font-size: 26px;
      }

      .nav-title {
        font-size: 18px;
      }

      .nav-description {
        font-size: 14px;
      }
    }
  </style>
</head>

<body>
  <main class="app">
    <header class="header">
      <button class="menu-button" type="button" aria-label="Open menu">
        ☰
      </button>

      <div class="header-title">
        <span class="header-icon">🛡️</span>
        REALTOR GUARD
      </div>
    </header>

    <section class="content">
      <img
        src="./logo.png"
        alt="Realtor Guard — Never Alone at a Showing or Open House"
        class="logo"
      >

      <nav class="navigation" aria-label="Main navigation">
        <a class="nav-card" href="#">
          <span class="nav-icon" aria-hidden="true">⌂</span>

          <span>
            <span class="nav-title">New Agent</span>
            <span class="nav-description">
              Create your agent account
            </span>
          </span>

          <span class="arrow" aria-hidden="true">›</span>
        </a>

        <a class="nav-card" href="#">
          <span class="nav-icon" aria-hidden="true">🔑</span>

          <span>
            <span class="nav-title">Agent Dashboard</span>
            <span class="nav-description">
              Log in to your agent account
            </span>
          </span>

          <span class="arrow" aria-hidden="true">›</span>
        </a>

        <a class="nav-card" href="#">
          <span class="nav-icon" aria-hidden="true">🛡</span>

          <span>
            <span class="nav-title">New Observer</span>
            <span class="nav-description">
              Sign up and start verification
            </span>
          </span>

          <span class="arrow" aria-hidden="true">›</span>
        </a>

        <a class="nav-card" href="#">
          <span class="nav-icon" aria-hidden="true">●</span>

          <span>
            <span class="nav-title">Observer Dashboard</span>
            <span class="nav-description">
              Log in to your observer account
            </span>
          </span>

          <span class="arrow" aria-hidden="true">›</span>
        </a>
      </nav>

      <section class="location-card">
        <div class="location-icon" aria-hidden="true">⌖</div>

        <div>
          <div class="location-title">Virginia Active</div>
          <div class="location-text">More states coming soon.</div>
        </div>
      </section>
    </section>
  </main>
</body>
</html>
